{
  "name": "ben-tenison",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate --schema=prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema=prisma/schema.prisma",
    "prisma:reset": "prisma migrate reset --schema=prisma/schema.prisma --force",
    "prisma:db:pull": "prisma db pull --schema=prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema=prisma/schema.prisma"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
