// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["schemaEngineDriverAdapters"]
}
datasource db {
  provider = "postgresql"
}

model Store {
  id        String      @id @default(cuid())
  name      String      @unique
  location  String
  inventory Inventory[]
  sales     Sale[]
  users     User[]      // Relación añadida para RF04
}

model Product {
  id          String    @id @default(cuid())
  name        String
  brand       String
  description String?
  category    String    @default("CASUAL") // Sugerido para filtros RF08
  variants    Variant[]
}

model Variant {
  id        String      @id @default(cuid())
  sku       String      @unique
  size      String
  color     String
  price     Decimal     @db.Decimal(10, 2)
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory Inventory[]
  saleItems SaleItem[]
}

model Inventory {
  id        String  @id @default(cuid())
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id])
  quantity  Int     @default(0)
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])

  @@unique([storeId, variantId])
}

model Sale {
  id        String     @id @default(cuid())
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  total     Decimal    @db.Decimal(10, 2)
  createdAt DateTime   @default(now())
  items     SaleItem[]
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2) // Precio original (RF05)
  salePrice Decimal @db.Decimal(10, 2) // Precio con descuento aplicado (RF06)
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String // Almacenado con hash (RNF04)
  role     Role   @default(CASHIER)
  storeId  String? 
  store    Store? @relation(fields: [storeId], references: [id])
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}