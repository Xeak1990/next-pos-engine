// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]  
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id        String      @id @default(cuid())
  name      String      @unique
  location  String
  inventory Inventory[]
  sales     Sale[]
  users     User[]      // Relación añadida para RF04
}

model Product {
  id          String    @id @default(cuid())
  name        String
  brand       String
  description String?
  category    String    @default("CASUAL") // Sugerido para filtros RF08
  variants    Variant[]
}

model Variant {
  id        String      @id @default(cuid())
  sku       String      @unique
  size      String
  color     String
  price     Decimal     @db.Decimal(10, 2)
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory Inventory[]
  saleItems SaleItem[]
}

model Inventory {
  id        String  @id @default(cuid())
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id])
  quantity  Int     @default(0)
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])

  @@unique([storeId, variantId])
}

model Sale {
  id        String     @id @default(cuid())
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  total     Decimal    @db.Decimal(10, 2)
  createdAt DateTime   @default(now())
  items     SaleItem[]
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2) // Precio original (RF05)
  salePrice Decimal @db.Decimal(10, 2) // Precio con descuento aplicado (RF06)
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String // Almacenado con hash (RNF04)
  role     Role   @default(CASHIER)
  storeId  String?
  store    Store? @relation(fields: [storeId], references: [id])
  isActive Boolean @default(true)
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

model Order {
  id             String      @id @default(cuid())
  customerName   String
  customerEmail  String
  customerPhone  String?
  address        String
  city           String
  postalCode     String
  paymentMethod  String
  total          Float
  status         String      @default("pending")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]
  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  name      String
  price     Float
  quantity  Int
  size      String?
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  address   String?
  city      String?
  postalCode String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}